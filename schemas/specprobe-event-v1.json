{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specprobe.dev/schemas/specprobe-event-v1.json",
  "title": "SpecProbeEventV1",
  "description": "One JSONL line emitted by the vLLM rejection_sample monkey-patch.",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "draft_strategy",
    "draft_tokens",
    "p_draft",
    "p_target",
    "acceptance_mask"
  ],
  "properties": {
    "schema_version": { "const": "specprobe.event.v1" },
    "ts": { "type": "string" },
    "run_id": { "type": "string" },
    "request_id": { "type": "string" },
    "step": { "type": "integer" },
    "req_index": { "type": "integer" },
    "draft_strategy": { "type": "string" },
    "prompt": { "type": ["string", "null"] },
    "temperature": { "type": ["number", "null"] },
    "draft_probs_available": { "type": "boolean" },
    "num_draft_tokens": { "type": "integer" },
    "draft_tokens": { "type": "array", "items": { "type": "integer" } },
    "p_draft": { "type": "array", "items": { "type": "number" } },
    "p_target": { "type": "array", "items": { "type": "number" } },
    "accept_prob": { "type": "array", "items": { "type": "number" } },
    "rolls": {
      "type": ["array", "null"],
      "items": { "type": ["number", "null"] }
    },
    "acceptance_mask": { "type": "array", "items": { "type": "boolean" } },
    "rejected_at": { "type": ["integer", "null"] },
    "accepted_tokens": { "type": "array", "items": { "type": "integer" } },
    "recovered_token": { "type": ["integer", "null"] },
    "bonus_token": { "type": ["integer", "null"] },
    "output_composition": { "type": "string" },
    "output_token_ids": { "type": "array", "items": { "type": "integer" } }
  }
}
