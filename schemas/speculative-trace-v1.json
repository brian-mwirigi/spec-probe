{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specprobe.dev/schemas/speculative-trace-v1.json",
  "title": "SpeculativeTraceV1",
  "description": "Thin wire format from a vLLM (or compatible) sampler hook into the SpecProbe verification lane. One file = one speculative block (or a request with multiple blocks).",
  "type": "object",
  "required": ["schema_version", "trace_id", "created_at", "engine", "request", "blocks"],
  "properties": {
    "schema_version": { "const": "specprobe.trace.v1" },
    "trace_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "engine": {
      "type": "object",
      "required": ["name", "draft_strategy"],
      "properties": {
        "name": { "type": "string", "examples": ["vllm", "simulator"] },
        "version": { "type": ["string", "null"] },
        "draft_strategy": {
          "type": "string",
          "enum": ["eagle", "medusa", "ngram", "draft_model", "unknown"]
        },
        "target_model": { "type": ["string", "null"] },
        "draft_model": { "type": ["string", "null"] },
        "temperature": { "type": "number" },
        "extra": { "type": "object", "additionalProperties": true }
      }
    },
    "request": {
      "type": "object",
      "required": ["prompt"],
      "properties": {
        "prompt": { "type": "string" },
        "request_id": { "type": ["string", "null"] },
        "domain_hint": {
          "type": ["string", "null"],
          "enum": ["python", "prose", "mixed", null]
        }
      }
    },
    "blocks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/block" }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "wall_time_ms": { "type": ["number", "null"] },
        "acceptance_rate": { "type": ["number", "null"] },
        "tokens_accepted": { "type": ["integer", "null"] },
        "tokens_drafted": { "type": ["integer", "null"] }
      }
    }
  },
  "$defs": {
    "block": {
      "type": "object",
      "required": ["block_index", "tokens"],
      "properties": {
        "block_index": { "type": "integer", "minimum": 0 },
        "draft_len": { "type": "integer" },
        "rejected_at": { "type": ["integer", "null"] },
        "bonus_token": {
          "type": ["object", "null"],
          "properties": {
            "token_id": { "type": ["integer", "null"] },
            "token": { "type": "string" },
            "display": { "type": "string" },
            "target_prob": { "type": "number" }
          }
        },
        "tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/token" }
        },
        "structural_failures": {
          "type": "array",
          "items": { "$ref": "#/$defs/failure" }
        }
      }
    },
    "token": {
      "type": "object",
      "required": [
        "index",
        "token",
        "draft_prob",
        "target_prob",
        "accept_prob",
        "outcome"
      ],
      "properties": {
        "index": { "type": "integer", "minimum": 0 },
        "token_id": { "type": ["integer", "null"] },
        "token": { "type": "string" },
        "display": { "type": "string" },
        "draft_prob": { "type": "number", "minimum": 0, "maximum": 1 },
        "target_prob": { "type": "number", "minimum": 0, "maximum": 1 },
        "ratio": { "type": "number" },
        "accept_prob": { "type": "number", "minimum": 0, "maximum": 1 },
        "roll": { "type": ["number", "null"] },
        "outcome": {
          "type": "string",
          "enum": ["accepted", "rejected", "unverified", "bonus"]
        },
        "tag": {
          "type": ["string", "null"],
          "enum": ["indent", "syntax", "phrasing", "boundary", "overconfidence", null]
        },
        "reason": { "type": ["string", "null"] }
      }
    },
    "failure": {
      "type": "object",
      "required": ["kind", "label", "detail", "token_index"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["indent", "syntax", "phrasing", "boundary", "overconfidence"]
        },
        "label": { "type": "string" },
        "detail": { "type": "string" },
        "token_index": { "type": "integer" }
      }
    }
  }
}
